{
  "name": "@neoma/fixtures",
  "version": "0.6.1",
  "description": "Test fixtures for @neoma/* NestJS packages",
  "author": "Daniel Bruce",
  "repository": {
    "type": "git",
    "url": "https://github.com/neomaventures/pack",
    "directory": "packages/fixtures"
  },
  "bugs": {
    "url": "https://github.com/neomaventures/pack/issues"
  },
  "homepage": "https://github.com/neomaventures/pack/tree/main/packages/fixtures#readme",
  "keywords": [
    "nestjs",
    "fixtures",
    "testing",
    "neoma"
  ],
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./matchers": {
      "require": "./dist/matchers/index.js",
      "types": "./dist/matchers/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!**/*.json",
    "!**/*.tsbuildinfo"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc -p ./tsconfig.lib.json",
    "test": "jest --runInBand --passWithNoTests",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "@nestjs/common": "11.x",
    "@types/express": ">=4",
    "@types/jest": ">=29.0.0",
    "jest": ">=29.0.0"
  },
  "dependencies": {
    "@faker-js/faker": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0"
  }
}
