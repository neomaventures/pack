{
  "name": "@neomaventures/fixtures",
  "version": "0.5.0",
  "description": "Test fixtures for @neomaventures/* NestJS packages",
  "author": "Daniel Bruce",
  "repository": {
    "type": "git",
    "url": "https://github.com/neomaventures/pack",
    "directory": "packages/fixtures"
  },
  "bugs": {
    "url": "https://github.com/neomaventures/pack/issues"
  },
  "homepage": "https://github.com/neomaventures/pack/tree/main/packages/fixtures#readme",
  "keywords": [
    "nestjs",
    "fixtures",
    "testing",
    "neoma"
  ],
  "private": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./matchers": {
      "require": "./dist/matchers/index.js",
      "types": "./dist/matchers/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!**/*.json",
    "!**/*.tsbuildinfo"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc -p ./tsconfig.lib.json",
    "test": "jest --runInBand --passWithNoTests",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "@nestjs/common": "11.x",
    "@types/express": ">=4",
    "@types/jest": ">=29.0.0",
    "jest": ">=29.0.0",
    "rxjs": ">=7"
  },
  "dependencies": {
    "@faker-js/faker": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.18",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "jest": "^30.3.0",
    "jest-extended": "^7.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  }
}
