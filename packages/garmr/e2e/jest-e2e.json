{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "setupFiles": ["<rootDir>/build.setup.ts"],
  "setupFilesAfterEnv": ["jest-extended/all", "@neoma/fixtures/matchers"],
  "globalSetup": "<rootDir>/../fixtures/e2e/global-setup.ts",
  "globalTeardown": "<rootDir>/../fixtures/e2e/global-teardown.ts",
  "transform": {
    "^.+\\.tsx?$": "ts-jest"
  },
  "moduleNameMapper": {
    "^fixtures/(.*)$": "<rootDir>/../fixtures/$1",
    "^@neoma/garmr$": "<rootDir>/../dist/index.js",
    "^@neoma/garmr/(.*)$": "<rootDir>/../dist/$1"
  }
}
