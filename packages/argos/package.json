    "lint": "eslint ."
  },
  "peerDependencies": {
    "@nestjs/common": "11.x",
    "@nestjs/core": "11.x",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@neoma/managed-app": "workspace:*",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/testing": "^11.1.18",
    "@nestjs/typeorm": "^11.0.0",
    "@types/supertest": "^6.0.2",
    "sqlite3": "^5.1.7",
    "supertest": "^7.0.0",
    "typeorm": "^0.3.20"
  }
}
