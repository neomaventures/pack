{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "globalSetup": "@neoma/minio/setup",
  "globalTeardown": "@neoma/minio/teardown",
  "setupFiles": ["<rootDir>/build.setup.ts"],
  "setupFilesAfterEnv": ["jest-extended/all", "@neoma/fixtures/matchers"],
  "transform": {
    "^.+\\.tsx?$": "ts-jest"
  },
  "moduleNameMapper": {
    "fixtures/(.*)$": "<rootDir>/../fixtures/$1",
    "^@neoma/cerberus$": "<rootDir>/../dist/index.js",
    "^@neoma/cerberus/(.*)$": "<rootDir>/../dist/$1"
  }
}
