{
  "name": "@neomaventures/mailpit",
  "version": "0.1.0",
  "description": "Mailpit test fixture for @neomaventures/* \u2014 a reusable client plus Docker container lifecycle and Jest setup/teardown drop-ins for email testing.",
  "author": "Daniel Bruce",
  "repository": {
    "type": "git",
    "url": "https://github.com/neomaventures/pack",
    "directory": "packages/mailpit"
  },
  "bugs": {
    "url": "https://github.com/neomaventures/pack/issues"
  },
  "homepage": "https://github.com/neomaventures/pack/tree/main/packages/mailpit#readme",
  "keywords": [
    "neoma",
    "testing",
    "mailpit",
    "email",
    "docker",
    "jest"
  ],
  "private": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./setup": {
      "require": "./dist/setup.js",
      "types": "./dist/setup.d.ts"
    },
    "./teardown": {
      "require": "./dist/teardown.js",
      "types": "./dist/teardown.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!**/*.json",
    "!**/*.tsbuildinfo"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc -p ./tsconfig.lib.json",
    "test": "jest --runInBand --passWithNoTests",
    "pretest:e2e": "pnpm build",
    "test:e2e": "NEOMA_TEST_PREFIX=mailpit-e2e MAILPIT_SMTP_PORT=10125 MAILPIT_API_PORT=10825 jest --config ./e2e/jest-e2e.json --runInBand",
    "lint": "eslint ."
  },
  "dependencies": {
    "@neomaventures/docker": "workspace:*"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.6.0",
    "@types/nodemailer": "^8.0.0",
    "nodemailer": "^8.0.7"
  }
}
