{
  "name": "@neomaventures/route-model-binding",
  "version": "0.5.0",
  "description": "Laravel-inspired route model binding for NestJS — automatically resolve database models from route parameters.",
  "author": "Daniel Bruce",
  "repository": {
    "type": "git",
    "url": "https://github.com/neomaventures/pack",
    "directory": "packages/route-model-binding"
  },
  "bugs": {
