{
  "name": "@neomaventures/mailbox",
  "version": "0.0.0",
  "description": "Provider-agnostic mailbox primitive for NestJS. Gmail-first.",
  "author": "Daniel Bruce",
  "repository": {
    "type": "git",
    "url": "https://github.com/neomaventures/pack",
    "directory": "packages/mailbox"
  },
  "bugs": {
    "url": "https://github.com/neomaventures/pack/issues"
  },
  "homepage": "https://github.com/neomaventures/pack/tree/main/packages/mailbox#readme",
  "keywords": [
    "nestjs",
    "neoma",
    "mailbox",
    "gmail",
    "email"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!**/*.json",
    "!**/*.tsbuildinfo"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc -p ./tsconfig.lib.json",
    "test": "node --env-file=.env.test ./node_modules/jest/bin/jest.js --runInBand --passWithNoTests",
    "pretest:e2e": "pnpm build",
    "test:e2e": "node --env-file=.env.e2e --experimental-vm-modules ./node_modules/jest/bin/jest.js --config ./e2e/jest-e2e.json --runInBand",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "@nestjs/common": "11.x",
    "@nestjs/core": "11.x",
    "typeorm": ">=0.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.6.0",
    "@neomaventures/fixtures": "workspace:*",
    "@neomaventures/google-fixtures": "workspace:*",
    "@neomaventures/managed-app": "workspace:*",
    "@neomaventures/managed-database": "workspace:*",
    "@neomaventures/mockserver": "workspace:*",
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.18",
    "@nestjs/testing": "^11.1.18",
    "@nestjs/typeorm": "^11.0.0",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^6.0.2",
    "jest": "^30.3.0",
    "jest-extended": "^7.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sqlite3": "^5.1.7",
    "supertest": "^7.0.0",
    "typeorm": "^0.3.20"
  }
}
