{
  "name": "@neoma/minio",
  "version": "0.0.0",
  "description": "MinIO test fixture for @neoma/* — S3-compatible object storage via a Docker container, with a bucket created on start and Jest setup/teardown drop-ins.",
  "author": "Shipdventures",
  "repository": {
    "type": "git",
    "url": "https://github.com/neomaventures/pack",
    "directory": "packages/minio"
  },
  "bugs": {
    "url": "https://github.com/neomaventures/pack/issues"
  },
  "homepage": "https://github.com/neomaventures/pack/tree/main/packages/minio#readme",
  "keywords": [
    "neoma",
    "testing",
    "minio",
    "s3",
    "docker",
    "jest"
  ],
  "private": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./setup": {
      "require": "./dist/setup.js",
      "types": "./dist/setup.d.ts"
    },
    "./teardown": {
      "require": "./dist/teardown.js",
      "types": "./dist/teardown.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!**/*.json",
    "!**/*.tsbuildinfo"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc -p ./tsconfig.lib.json",
    "test": "jest --runInBand --passWithNoTests",
    "pretest:e2e": "pnpm build",
    "test:e2e": "NEOMA_TEST_PREFIX=minio-e2e MINIO_PORT=9010 MINIO_CONSOLE_PORT=9011 jest --config ./e2e/jest-e2e.json --runInBand",
    "lint": "eslint ."
  },
  "dependencies": {
    "@neoma/docker": "workspace:*"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.6.0"
  }
}
