{
  "name": "@neomaventures/minio",
  "version": "0.2.0",
  "description": "MinIO test fixture for @neomaventures/* — S3-compatible object storage via a Docker container, with a bucket created on start and Jest setup/teardown drop-ins.",
  "author": "Daniel Bruce",
  "repository": {
    "type": "git",
    "url": "https://github.com/neomaventures/pack",
    "directory": "packages/minio"
  },
  "bugs": {
    "url": "https://github.com/neomaventures/pack/issues"
  },
  "homepage": "https://github.com/neomaventures/pack/tree/main/packages/minio#readme",
  "keywords": [
    "neoma",
    "testing",
    "minio",
    "s3",
    "docker",
    "jest"
  ],
  "private": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./setup": {
      "require": "./dist/setup.js",
      "types": "./dist/setup.d.ts"
    },
    "./teardown": {
      "require": "./dist/teardown.js",
      "types": "./dist/teardown.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!**/*.json",
    "!**/*.tsbuildinfo"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc -p ./tsconfig.lib.json",
    "test": "jest --runInBand --passWithNoTests",
    "pretest:e2e": "pnpm build",
    "test:e2e": "node --env-file=.env.e2e ./node_modules/jest/bin/jest.js --config ./e2e/jest-e2e.json --runInBand",
    "lint": "eslint ."
  },
  "dependencies": {
    "@neomaventures/docker": "workspace:*"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.6.0",
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "jest-extended": "^7.0.0",
    "reflect-metadata": "^0.2.2",
    "ts-jest": "^29.4.9"
  }
}
