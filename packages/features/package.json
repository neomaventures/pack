{
  "name": "@neoma/features",
  "version": "0.4.0",
  "description": "Feature flagging for NestJS controllers — gate routes behind binary on/off flags.",
  "author": "Daniel Bruce",
  "repository": {
    "type": "git",
    "url": "https://github.com/neomaventures/pack",
    "directory": "packages/features"
  },
  "bugs": {
    "url": "https://github.com/neomaventures/pack/issues"
  },
  "homepage": "https://github.com/neomaventures/pack/tree/main/packages/features#readme",
  "keywords": [
    "nestjs",
    "feature-flags",
    "feature-gating",
    "neoma"
  ],
  "private": false,
  "publishConfig": { "registry": "https://npm.pkg.github.com" },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!**/*.json",
    "!**/*.tsbuildinfo"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc -p ./tsconfig.lib.json",
    "test": "jest --runInBand --passWithNoTests",
    "pretest:e2e": "pnpm build",
    "test:e2e": "NEOMA_MANAGED_APP_MODULE_PATH=e2e/app/app.module.ts#AppModule NODE_OPTIONS=--experimental-vm-modules jest --config ./e2e/jest-e2e.json --runInBand",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "@nestjs/common": "11.x",
    "@nestjs/core": "11.x",
    "express": ">=4",
    "reflect-metadata": ">=0.2",
    "rxjs": ">=7"
  },
  "devDependencies": {
    "@neoma/fixtures": "workspace:*",
    "@neoma/managed-app": "workspace:*",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/testing": "^11.1.18",
    "@types/supertest": "^6.0.2",
    "sqlite3": "^5.1.7",
    "supertest": "^7.0.0",
    "typeorm": "^0.3.20"
  }
}
