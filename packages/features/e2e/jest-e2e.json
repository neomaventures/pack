{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "setupFiles": ["<rootDir>/build.setup.ts"],
  "setupFilesAfterEnv": [
    "jest-extended/all",
    "<rootDir>/../fixtures/matchers/index.js"
  ],
  "transform": {
    "^.+\\.tsx?$": "ts-jest"
  },
  "moduleNameMapper": {
    "fixtures/(.*)$": "<rootDir>/../fixtures/$1",
    "^@neoma/features$": "<rootDir>/../dist/index.js",
    "^@neoma/features/(.*)$": "<rootDir>/../dist/$1"
  }
}
