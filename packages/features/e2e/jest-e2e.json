{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "setupFiles": [
    "<rootDir>/build.setup.ts"
  ],
  "setupFilesAfterEnv": [
    "jest-extended/all"
  ],
  "transform": {
    "^.+\\.tsx?$": [
      "@swc/jest",
      {
        "jsc": {
          "parser": {
            "syntax": "typescript",
            "decorators": true,
            "dynamicImport": true
          },
          "transform": {
            "legacyDecorator": true,
            "decoratorMetadata": true
          }
        }
      }
    ]
  },
  "moduleNameMapper": {
    "fixtures/(.*)$": "<rootDir>/../fixtures/$1",
    "^@neomaventures/features$": "<rootDir>/../dist/index.js",
    "^@neomaventures/features/(.*)$": "<rootDir>/../dist/$1"
  }
}
