  "description": "Effective and automatic exception handling for NestJS.",
  "author": "Daniel Bruce",
  "repository": {
    "type": "git",
    "url": "https://github.com/neomaventures/pack",
    "directory": "packages/exceptions"
  },
  "bugs": {
    "url": "https://github.com/neomaventures/pack/issues"
  },
  "homepage": "https://github.com/neomaventures/pack/tree/main/packages/exceptions#readme",
  "keywords": [
