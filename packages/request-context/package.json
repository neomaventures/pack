{
  "name": "@neoma/request-context",
  "version": "0.1.0",
  "description": "Per-request context (AsyncLocalStorage) for NestJS — read the current request anywhere, no request scope.",
  "author": "Daniel Bruce",
  "repository": {
    "type": "git",
    "url": "https://github.com/neomaventures/pack",
    "directory": "packages/request-context"
  },
  "bugs": {
    "url": "https://github.com/neomaventures/pack/issues"
  },
  "homepage": "https://github.com/neomaventures/pack/tree/main/packages/request-context#readme",
  "keywords": [
    "nestjs",
    "neoma",
    "request-context"
  ],
  "private": false,
  "publishConfig": { "registry": "https://npm.pkg.github.com" },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!**/*.json",
    "!**/*.tsbuildinfo"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc -p ./tsconfig.lib.json",
    "test": "jest --runInBand --passWithNoTests",
    "pretest:e2e": "pnpm build",
    "test:e2e": "NODE_OPTIONS=--experimental-vm-modules jest --config ./e2e/jest-e2e.json --runInBand",
    "lint": "eslint ."
  },
  "dependencies": {
    "nestjs-cls": "6.2.0"
  },
  "peerDependencies": {
    "@nestjs/common": "11.x",
    "@nestjs/core": "11.x",
    "express": ">=4",
    "reflect-metadata": ">=0.2",
    "rxjs": ">=7"
  },
  "devDependencies": {
    "@neoma/fixtures": "workspace:*",
    "@neoma/managed-app": "workspace:*",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/testing": "^11.1.18",
    "@types/express": "^5.0.0",
    "@types/supertest": "^6.0.2",
    "express": "^5.0.0",
    "supertest": "^7.0.0"
  }
}
