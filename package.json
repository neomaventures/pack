{
  "name": "neoma-pack",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint && pnpm lint:yaml",
    "lint:yaml": "eslint \"**/*.{yml,yaml}\"",
    "release": "pnpm -r build && changeset publish",
    "new-package": "bash scripts/new-package.sh",
    "check:readme": "node scripts/check-readme-packages.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.12.1",
    "@swc/jest": "^0.2.39",
    "@faker-js/faker": "^9.6.0",
    "@nestjs/common": "^11.1.18",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/nodemailer": "^8.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-yml": "^3.3.2",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jest-extended": "^7.0.0",
    "jest-matcher-utils": "^30.4.1",
    "nodemailer": "^8.0.7",
    "prettier": "^3.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
