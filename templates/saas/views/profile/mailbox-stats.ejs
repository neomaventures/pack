<div class="flex items-center justify-end gap-3 text-sm text-slate-700">
  <span class="text-xs uppercase tracking-wide text-slate-500"><%= mailboxStats.folder %></span>
  <span>
    <strong class="font-semibold text-slate-800"><%= mailboxStats.messageCount %></strong>
    <span class="text-slate-500">messages</span>
    <span class="text-slate-300">·</span>
    <strong class="font-semibold text-slate-800"><%= mailboxStats.unreadCount %></strong>
    <span class="text-slate-500">unread</span>
  </span>
</div>
