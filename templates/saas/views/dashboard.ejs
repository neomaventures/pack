<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard - <%= npmPackageName %></title>
    <link rel="stylesheet" href="/stylesheets/main.css" />
  </head>
  <body class="flex min-h-screen flex-col bg-slate-50 font-sans text-slate-800">
    <header
      class="flex items-center justify-between border-b border-slate-200 bg-white px-8 py-4"
    >
      <span class="text-lg font-bold tracking-tight"
        ><%= npmPackageName %></span
      >
      <nav class="flex gap-4">
        <form method="post" action="/auth/logout">
          <button
            type="submit"
            class="cursor-pointer border-none bg-transparent p-0 font-sans text-sm font-medium text-slate-800 hover:text-slate-500"
          >
            Sign out
          </button>
        </form>
      </nav>
    </header>

    <main
      class="flex flex-1 flex-col items-center justify-center px-6 py-16 text-center"
    >
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-800">
        Dashboard
      </h1>
      <p class="mt-3 text-lg text-slate-500"><%= email %></p>
    </main>

    <footer class="px-8 py-4 text-right text-xs text-slate-500">
      <span>v<%= npmPackageVersion %></span>
    </footer>
  </body>
</html>
