<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>System status - <%= npmPackageName %></title>
    <link rel="stylesheet" href="/stylesheets/main.css" />
  </head>
  <body class="flex min-h-screen flex-col bg-slate-50 font-sans text-slate-800">
    <header
      class="flex items-center justify-between border-b border-slate-200 bg-white px-8 py-4"
    >
      <span class="text-lg font-bold tracking-tight"
        ><%= npmPackageName %></span
      >
    </header>

    <main class="flex flex-1 flex-col items-center px-6 py-16">
      <div class="w-full max-w-2xl">
        <%
          // Probe data is namespaced under `result` so it doesn't collide
          // with the view-engine globals merged into `locals`
          // (npmPackageName etc.). Split the timestamp out from the probe
          // entries so it doesn't render as a per-probe row.
          const { checkedAt, ...probes } = result
          const degraded = Object.values(probes).some(v => v === "error")
        %>
        <% if (degraded) { %>
          <div
            class="rounded-md bg-red-100 px-6 py-4 text-center text-lg font-semibold text-red-800"
          >
            Service degraded
          </div>
        <% } else { %>
          <div
            class="rounded-md bg-green-100 px-6 py-4 text-center text-lg font-semibold text-green-800"
          >
            All systems operational
          </div>
        <% } %>

        <ul class="mt-8 divide-y divide-slate-200 rounded-md border border-slate-200 bg-white">
          <% for (const [name, status] of Object.entries(probes)) { %>
            <li class="flex items-center justify-between px-6 py-4">
              <span class="font-medium capitalize"><%= name %></span>
              <% if (status === "ok") { %>
                <span
                  class="rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-800"
                  >ok</span
                >
              <% } else { %>
                <span
                  class="rounded-full bg-red-100 px-3 py-1 text-xs font-semibold text-red-800"
                  >error</span
                >
              <% } %>
            </li>
          <% } %>
        </ul>

        <p class="mt-6 text-center text-sm text-slate-500">
          Last checked at <%= checkedAt.toISOString() %>
        </p>
        <!--
          checkedAt is a Date instance — the template owns the formatting.
          Switch to .toLocaleString(...) or a date-fns helper if you want
          a more operator-friendly format.
        -->

      </div>
    </main>

    <footer class="px-8 py-4 text-right text-xs text-slate-500">
      <span>v<%= npmPackageVersion %></span>
    </footer>
  </body>
</html>
