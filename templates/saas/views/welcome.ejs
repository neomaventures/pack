<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= npmPackageName %></title>
    <link rel="stylesheet" href="/stylesheets/main.css" />
  </head>
  <body class="min-h-screen flex flex-col bg-slate-50 text-slate-800 font-sans">
    <header class="flex items-center justify-between px-8 py-4 border-b border-slate-200 bg-white">
      <span class="font-bold text-lg tracking-tight"><%= npmPackageName %></span>
      <nav class="flex gap-4">
        <a href="/auth/register" class="text-sm font-medium text-slate-800 no-underline hover:text-slate-500">Sign in</a>
      </nav>
    </header>

    <main class="flex-1 flex flex-col items-center justify-center text-center px-6 py-16">
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-800">Welcome to <%= npmPackageName %></h1>
      <p class="mt-3 text-lg text-slate-500 max-w-lg">
        A modern SaaS starter built with NestJS and EJS.
      </p>
    </main>

    <footer class="px-8 py-4 text-right text-xs text-slate-500">
      <span>v<%= npmPackageVersion %></span>
    </footer>
  </body>
</html>
