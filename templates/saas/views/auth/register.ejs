<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign up - <%= npmPackageName %></title>
    <link rel="stylesheet" href="/stylesheets/main.css" />
  </head>
  <body>
    <main class="auth-card">
      <h1 class="auth-title">Sign up</h1>

      <form class="auth-form" action="/auth/register" method="POST">
        <label class="auth-label" for="email">Email address</label>
        <input
          class="auth-input<%= typeof exception !== 'undefined' && exception.email ? ' auth-input--error' : '' %>"
          id="email"
          name="email"
          type="text"
          placeholder="you@example.com"
          value="<%= typeof exception !== 'undefined' && exception.email ? exception.email.value : '' %>"
        />
        <% if (typeof exception !== "undefined" && exception.email) { %>
          <p class="auth-error"><%= exception.email.error %></p>
        <% } %>
        <button class="auth-button" type="submit">Continue with email</button>
      </form>

      <div class="auth-divider"><span>or</span></div>

      <button class="auth-button auth-button--google" type="button" disabled>
        Continue with Google
      </button>

      <a href="/" class="auth-back-link">&larr; Back to home</a>
    </main>

    <footer class="footer">
      <span>v<%= npmPackageVersion %></span>
    </footer>
  </body>
</html>
