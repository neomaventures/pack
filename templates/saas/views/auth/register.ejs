<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign up - <%= npmPackageName %></title>
    <link rel="stylesheet" href="/stylesheets/main.css" />
  </head>
  <body class="min-h-screen flex flex-col bg-slate-50 text-slate-800 font-sans">
    <main class="flex-1 flex flex-col items-center justify-center px-6 py-16 max-w-sm mx-auto w-full">
      <h1 class="text-2xl font-extrabold tracking-tight mb-8">Sign up</h1>

      <form class="flex flex-col w-full" action="/auth/register" method="POST" novalidate>
        <label class="text-sm font-medium mb-1.5" for="email">Email address</label>
        <input
          class="px-3 py-2.5 border rounded-md text-sm font-sans mb-3 outline-none focus:border-slate-800 <%= typeof exception !== 'undefined' && exception.email ? 'border-red-600' : 'border-slate-200' %>"
          id="email"
          name="email"
          type="email"
          placeholder="you@example.com"
          value="<%= typeof exception !== 'undefined' && exception.email ? exception.email.value : '' %>"
        />
        <% if (typeof exception !== "undefined" && exception.email) { %>
          <p class="text-[0.8125rem] text-red-600 -mt-2 mb-3"><%= exception.email.error %></p>
        <% } %>
        <button class="px-4 py-2.5 border border-slate-200 rounded-md bg-slate-800 text-white text-sm font-medium font-sans cursor-pointer w-full hover:opacity-90" type="submit">Continue with email</button>
      </form>

      <div class="flex items-center w-full my-5 text-slate-500 text-xs before:flex-1 before:border-b before:border-slate-200 after:flex-1 after:border-b after:border-slate-200"><span class="px-3">or</span></div>

      <button class="px-4 py-2.5 border border-slate-200 rounded-md bg-white text-slate-800 text-sm font-medium font-sans cursor-pointer w-full hover:opacity-90 disabled:opacity-50 disabled:cursor-not-allowed" type="button" disabled>
        Continue with Google (coming soon)
      </button>

      <a href="/" class="mt-6 text-sm text-slate-500 no-underline hover:text-slate-800">&larr; Back to home</a>
    </main>

    <footer class="px-8 py-4 text-right text-xs text-slate-500">
      <span>v<%= npmPackageVersion %></span>
    </footer>
  </body>
</html>
