# Copy to `.env.development` (or per-environment file) and fill in values.

# Database connection. `:memory:` selects in-process SQLite — handy for local
# development and tests but loses state on restart. Use a `postgresql://...`
# URI for production.
DATABASE_URI=:memory:

# Secret used to sign JWT session cookies. Generate with `openssl rand -hex 32`.
JWT_SECRET=replace-me

# Outbound mail server. `pnpm dev` starts a local Mailpit container on :1025.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=noreply@localhost

# Public URL the app is reachable at; used to build links in transactional email.
APP_URL=http://localhost:3000

# Google OAuth credentials. Leave blank to disable the Google sign-in flow.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# S3-compatible object storage used by `@neomaventures/storage`. Defaults below
# point at a local MinIO running on :9000 with the standard root credentials.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=uploads
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
