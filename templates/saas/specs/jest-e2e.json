{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": "..",
  "testRegex": ".*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "@swc/jest"
  },
  "moduleNameMapper": {
    "^~fixtures/(.*)$": "<rootDir>/fixtures/$1",
    "^~(.*)$": "<rootDir>/src/$1"
  },
  "globalSetup": "<rootDir>/fixtures/e2e/global-setup.ts",
  "globalTeardown": "<rootDir>/fixtures/e2e/global-teardown.ts",
  "testEnvironment": "node",
  "setupFilesAfterEnv": [
    "jest-extended/all",
    "@neomaventures/fixtures/matchers"
  ]
}
