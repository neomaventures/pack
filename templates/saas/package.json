{
  "name": "__PACKAGE_NAME__",
  "version": "0.0.0",
  "description": "SaaS starter template and integration test bed for @neomaventures/* packages",
  "private": true,
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "nest build",
    "predev": "lsof -ti:3000 | xargs kill -9 2>/dev/null; docker start saas-mailpit 2>/dev/null || docker run -d --name saas-mailpit -p 1025:1025 -p 8025:8025 axllent/mailpit",
    "dev": "node --env-file=.env.development node_modules/@nestjs/cli/bin/nest.js start --watch",
    "postdev": "docker stop saas-mailpit",
    "typecheck": "tsc --noEmit",
    "start:prod": "node dist/main",
    "test": "node --env-file=.env.spec --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.json",
    "test:e2e": "node --env-file=.env.e2e-spec --experimental-vm-modules node_modules/jest/bin/jest.js --config ./specs/jest-e2e.json --runInBand",
    "test:ui": "node --env-file=.env.ui-spec node_modules/@playwright/test/cli.js test"
  },
  "dependencies": {
    "@neomaventures/auth": "workspace:*",
    "@neomaventures/config": "workspace:*",
    "@neomaventures/exceptions": "workspace:*",
    "@neomaventures/logging": "workspace:*",
    "@neomaventures/request-context": "workspace:*",
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.18",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/typeorm": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ejs": "^3.1.10",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@neomaventures/fixtures": "workspace:*",
    "@neomaventures/mailpit": "workspace:*",
    "@neomaventures/managed-app": "workspace:*",
    "@neomaventures/managed-database": "workspace:*",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/testing": "^11.1.18",
    "@playwright/test": "^1.58.2",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.12.1",
    "@swc/jest": "^0.2.39",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "jsonwebtoken": "^9.0.2",
    "supertest": "^7.2.2",
    "typescript": "^6.0.2"
  }
}
