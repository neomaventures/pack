{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": "src",
  "testRegex": ".*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "@swc/jest"
  },
  "moduleNameMapper": {
    "^~fixtures/(.*)$": "<rootDir>/../fixtures/$1",
    "^~(.*)$": "<rootDir>/../src/$1"
  },
  "globalSetup": "<rootDir>/../fixtures/unit/global-setup.ts",
  "globalTeardown": "<rootDir>/../fixtures/unit/global-teardown.ts",
  "testEnvironment": "node",
  "maxWorkers": 1
}
