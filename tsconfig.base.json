{
  "compilerOptions": {
    "module": "commonjs",
    "allowJs": true,
    "declaration": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "ES2022",
    "sourceMap": true,
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "types": ["node", "jest"],
    "paths": {
      "fixtures/*": ["${configDir}/fixtures/*"],
      "@lib": ["${configDir}/src"],
      "@lib/*": ["${configDir}/src/*"]
    }
  }
}
